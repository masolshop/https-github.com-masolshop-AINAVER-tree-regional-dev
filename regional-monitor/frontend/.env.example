# 백엔드 API 베이스 URL (선택)
#  - 비워두면 자동 감지 (sandbox 호스트의 5173 → 8000 치환, localhost는 127.0.0.1:8000)
#  - 운영 환경에서는 명시적으로 지정 권장
# VITE_API_BASE=https://api.regionwatch.kr

# Google OAuth Client ID (선택)
#  - 비워두면 개발 모드: 페이크 ID 토큰을 백엔드로 전송 (백엔드도 GOOGLE_CLIENT_ID 미설정이면 검증 스킵)
#  - 운영: Google Cloud Console에서 발급한 OAuth 2.0 Client ID 입력
#    https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
